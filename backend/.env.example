# LLM Provider（支持任意 OpenAI 兼容 API）
OPENAI_API_KEY=
OPENAI_BASE_URL=                # 留空使用官方，或填 https://your-proxy/v1

# 模型配置
LLM_MODEL=qwen3.5-plus-2026-02-15
EMBEDDING_MODEL=tongyi-embedding-vision-plus-2026-03-06
EMBEDDING_DIM=1024

# Embedding Provider（留空则复用上面的 OPENAI 配置）
EMBEDDING_API_KEY=
EMBEDDING_BASE_URL=
# DashScope 多模态 embedding 专用端点（当模型是 tongyi-embedding-vision* 时使用）
DASHSCOPE_EMBEDDING_URL=https://dashscope.aliyuncs.com/api/v1/services/embeddings/multimodal-embedding/multimodal-embedding

# Milvus
MILVUS_URI=http://localhost:19530
MILVUS_TOKEN=
MILVUS_COLLECTION=paper_chunks
MILVUS_INDEX_TYPE=AUTOINDEX

# PostgreSQL（本地用 docker-compose.infra.yml；生产/远程填实际地址）
DATABASE_URL=postgresql://postgres:password@localhost:5432/ara

# 多端口 SSH 隧道示例（按需修改端口）：
# ssh -N \
#   -L 15432:127.0.0.1:5432 \
#   -L 16379:127.0.0.1:6379 \
#   -L 19530:127.0.0.1:19530 \
#   tencent-service

# Tavily Web Search（可选，Phase 2 ReviewNode 使用）
TAVILY_API_KEY=

DEBUG=false
CORS_ORIGINS=["http://localhost:3000"]
