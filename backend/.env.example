# LLM Provider（支持任意 OpenAI 兼容 API）
OPENAI_API_KEY=
OPENAI_BASE_URL=                # 留空使用官方，或填 https://your-proxy/v1

# 模型配置
LLM_MODEL=gpt-4o-mini
EMBEDDING_MODEL=text-embedding-3-small

# Embedding Provider（留空则复用上面的 OPENAI 配置）
EMBEDDING_API_KEY=
EMBEDDING_BASE_URL=

# Qdrant
QDRANT_URL=http://localhost:6333
QDRANT_API_KEY=

# PostgreSQL（本地用 docker-compose.infra.yml；生产/远程填实际地址）
DATABASE_URL=postgresql://postgres:password@localhost:5432/ara

DEBUG=false
CORS_ORIGINS=["http://localhost:3000"]
